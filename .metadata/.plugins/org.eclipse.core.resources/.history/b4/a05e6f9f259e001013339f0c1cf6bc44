package coding;

public class Pyramid {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int num=1;
		int rows=5;
		for(int i=0;i<=rows;i++)
		{
			for(int j=i;j<rows;j++)
			{
				System.out.print(" ");
			}
			for(int k=1;k<=i;k++)
			{
				System.out.println(num+" ");
				num++;
			}
		}

	}

}
