package Pages;

import java.time.Duration;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.testng.Assert;

import elements.Elements;

public class Productpage {
	private WebDriver driver;
	public Productpage(WebDriver driver) {
this.driver=driver;
	}
public void  products()
{ WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(10));

	driver.findElement(By.xpath(Elements.product)).click();
	try
	 {
	     WebElement popupClose = wait.until(
	             ExpectedConditions.elementToBeClickable(By.xpath("//div[@class='continue-prompt-text']"))
	     );
	    

	     popupClose.click();
	    
	     System.out.println("Popup closed");

	 }
	 catch (Exception e)
	 {
	     System.out.println("Popup not displayed");
	 }
	WebElement allproducttext=driver.findElement(By.xpath("//h2[@class='title text-center']"));
	allproducttext.isDisplayed();
	List<WebElement> listofproducts=driver.findElements(By.xpath("//div[@class='col-sm-9 padding-right']//div[@class='product-image-wrapper']"));
	System.out.println("Total products: " + listofproducts.size());

	for(WebElement product : listofproducts)
	{
	    String productName = product.findElement(By.xpath(".//p")).getText();
	    System.out.println(productName);
	}
	//int pro=listofproducts.size();
}

public void searchproduct() throws InterruptedException
{
	driver.findElement(By.xpath(Elements.searchproduct)).sendKeys("T-shirt");
	try
	 {
	     WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(10));

	     WebElement popupClose = wait.until(
	             ExpectedConditions.elementToBeClickable(By.xpath("//div[@class=\'continue-prompt-text\']"))
	     );

	     popupClose.click();
	     System.out.println("Popup closed");

	 }
	 catch (Exception e)
	 {
	     System.out.println("Popup not displayed");
	 }
 Thread.sleep(2000);
	driver.findElement(By.xpath(Elements.searchproductbutton)).click();
	
	List<WebElement> products = driver.findElements(
	        By.xpath("//div[@class='productinfo text-center']//p")
	);

	System.out.println("Total products found: " + products.size());

	for(WebElement product : products)
	{
	    String productName = product.getText();
	    System.out.println(productName);

	    Assert.assertTrue(productName.toLowerCase().contains("t-shirt"),
	            "Invalid product displayed: " + productName);
	}
	
}
}
